rules_version = '2';
// 元は Firebase コンソールに手貼りされていた運用中のルール（2026-07-14にコード化）。
// 「家族コードを知っていれば誰でも読み書きできる」という設計上の弱点は現状のまま。
// これは意図的：外部販売に向けた口座（アカウント）モデルへの移行（docs/APP_STORE_ROADMAP.md の
// Phase 4/7）で構造的に塞ぐ計画で、Phase 1時点ではルールをレビュー可能にすることが目的だった。
// 反映するときは `firebase deploy --only firestore:rules`（本番Firestoreへの変更のため、
// 実行前に必ず内容を確認すること）。
//
// Phase 2（TTSキーのサーバープロキシ化）で private サブコレクションを追加。
// ElevenLabsのAPIキーは families/{fam}/private/tts に保存し、Cloudflare Worker の
// GCPサービスアカウント（ルールを迂回できる）からのみ読み書きする。クライアントには一切見せない。
//
// 【重要な修正・2026-07-14】以前は `match /private/{document=**} { allow: if false }` と
// `match /{document=**} { allow: if request.auth != null }` を並べ、「private は具体的なパス
// なので優先される＝ロックダウン」と考えていたが、これは誤り。Firestoreのルールは
// 「より具体的なパスが優先」ではなく、マッチした全 allow の論理OR（1つでも真なら許可）。
// そのため private/tts に対して下のワイルドカードの `if request.auth != null` が真となり、
// 匿名ユーザーがElevenLabsキーを読み書きできていた（本番で実測・穴）。
// → ワイルドカード match /{document=**} を撤廃し、許可するサブコレクション（shared/members/
// sessions）だけを明示列挙する。private にはルールを一切書かない＝どの allow にもマッチせず
// デフォルト拒否になる（クライアントからは永久に触れない。サーバーのサービスアカウントのみ）。
//
// Phase 4 Slice 1（実アカウントモデル・メール＋パスワード、単独オーナーのみ）で
// accounts/{accountId} を追加。families/{fam}と違い匿名認証は許可しない
// （request.auth.token.firebase.sign_in_provider!='anonymous'）。所有者本人（uid一致）のみ
// 読み書き可＝家族コードのように知っていれば誰でも、という穴が無い。共有・招待（authorizedUsers/
// invites）はSlice 2以降。families/{fam}は Phase 7 の移行まで開けたまま（4桁コードを知れば誰でも
// shared/members を読み書き可という既知の弱点は残るが、それはアカウントモデルで構造的に塞ぐ）。
service cloud.firestore {
  match /databases/{database}/documents {
    match /families/{fam} {
      // families ドキュメント自体（v1親doc・resetAt ブロードキャスト）
      allow read, write: if request.auth != null;
      // 許可するサブコレクションだけを明示列挙する。private/** は意図的にルールを書かない
      // ＝デフォルト拒否（クライアント不可・Cloudflare Worker のサービスアカウントのみ触れる）。
      match /shared/{document=**} {
        allow read, write: if request.auth != null;
      }
      match /members/{document=**} {
        allow read, write: if request.auth != null;
      }
      match /sessions/{document=**} {
        allow read, write: if request.auth != null;
      }
    }
    match /accounts/{accountId} {
      allow read, write: if request.auth != null && request.auth.uid == accountId
                          && request.auth.token.firebase.sign_in_provider != 'anonymous';
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == accountId
                            && request.auth.token.firebase.sign_in_provider != 'anonymous';
      }
    }
  }
}
