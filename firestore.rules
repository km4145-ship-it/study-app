rules_version = '2';
// 元は Firebase コンソールに手貼りされていた運用中のルール（2026-07-14にコード化）。
// 「家族コードを知っていれば誰でも読み書きできる」という設計上の弱点は現状のまま。
// これは意図的：外部販売に向けた口座（アカウント）モデルへの移行（docs/APP_STORE_ROADMAP.md の
// Phase 4/7）で構造的に塞ぐ計画で、Phase 1時点ではルールをレビュー可能にすることが目的だった。
// 反映するときは `firebase deploy --only firestore:rules`（本番Firestoreへの変更のため、
// 実行前に必ず内容を確認すること）。
//
// Phase 2（TTSキーのサーバープロキシ化）で private サブコレクションを追加。
// ElevenLabsのAPIキーは families/{fam}/private/tts に保存し、Cloud Functions の
// Admin SDK（ルールを迂回できる）からのみ読み書きする。クライアントには一切見せない。
service cloud.firestore {
  match /databases/{database}/documents {
    match /families/{fam} {
      allow read, write: if request.auth != null;
      // private配下は「より具体的なパス」として下のワイルドカードより優先される＝完全ロックダウン
      match /private/{document=**} {
        allow read, write: if false;
      }
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
